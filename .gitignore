#  before PyInstaller builds the exe, so content is dynamic.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.hypothesis/
.pytest_cache/
cover/

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Project specific exclusions (large CSVs, numpy data, and local config)
*.csv
*.npy
results/
config.json
*.png
!icon.png
*.ico
